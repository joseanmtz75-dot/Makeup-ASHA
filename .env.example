# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# PostgreSQL (Prisma)
# DATABASE_URL: pooled connection (puerto 6543) — para runtime en serverless
# DIRECT_URL: direct connection (puerto 5432) — para migraciones
# Si tu password tiene caracteres especiales, URL-encódelos (ej. $ → %24)
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-X-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres"

# WhatsApp (link mágico)
WHATSAPP_NUMERO_PRINCIPAL=523312345678

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ASHA
