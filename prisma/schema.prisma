// Makeup ASHA — Schema Prisma
// Single-tenant: todas las tablas pertenecen a ASHA implícitamente.
// Fase 1: catálogo + clientas + compras directas + comprobantes + configuración.
// Fase 2: dinámicas de boletos + sorteo verificable + cancelaciones.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// CATÁLOGO
// ============================================

model Producto {
  id           String              @id @default(cuid())
  nombre       String
  descripcion  String?
  precio       Float
  stock        Int                 @default(0)
  categoria    CategoriaProducto
  sku          String?             @unique
  activo       Boolean             @default(true)
  destacado    Boolean             @default(false)
  variantes    Json?               // [{nombre: "Cherry", colorHex?: "#FF0000"}, ...]
  creadoEn     DateTime            @default(now()) @map("creado_en")
  actualizadoEn DateTime           @updatedAt @map("actualizado_en")

  imagenes     ImagenProducto[]
  compras      Compra[]
  dinamicas    Dinamica[]          // dinámicas donde este producto es el premio

  @@index([categoria])
  @@index([activo])
  @@map("productos")
}

model ImagenProducto {
  id         String   @id @default(cuid())
  productoId String   @map("producto_id")
  url        String
  orden      Int      @default(0)
  creadoEn   DateTime @default(now()) @map("creado_en")

  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@index([productoId])
  @@map("imagenes_producto")
}

// ============================================
// CLIENTAS
// ============================================

model Clienta {
  id              String       @id @default(cuid())
  telefono        String       @unique
  nombre          String
  email           String?
  direccion       String?
  municipio       Municipio?
  referenciaDir   String?      @map("referencia_dir")
  puntos          Int          @default(0)
  nivelActual     NivelClienta @default(BRONCE) @map("nivel_actual")
  referidaPorId   String?      @map("referida_por_id")
  userId          String?      @unique @map("user_id") // Supabase auth user, opcional
  notas           String?      // notas internas del admin
  ultimaCompraEn  DateTime?    @map("ultima_compra_en")
  creadaEn        DateTime     @default(now()) @map("creada_en")
  actualizadaEn   DateTime     @updatedAt @map("actualizada_en")

  referidaPor     Clienta?     @relation("Referidas", fields: [referidaPorId], references: [id])
  referidas       Clienta[]    @relation("Referidas")
  compras         Compra[]
  boletos         Boleto[]
  solicitudesCancelacion SolicitudCancelacion[]
  dinamicasGanadas Dinamica[]  @relation("ClientaGanadora")

  @@index([telefono])
  @@index([nivelActual])
  @@map("clientas")
}

// ============================================
// COMPRAS DIRECTAS DE CATÁLOGO
// ============================================

model Compra {
  id                String        @id @default(cuid())
  clientaId         String        @map("clienta_id")
  productoId        String        @map("producto_id")
  cantidad          Int
  precioUnitario    Float         @map("precio_unitario")
  total             Float
  estatus           EstatusCompra @default(PENDIENTE)
  comprobanteId     String?       @unique @map("comprobante_id")
  direccionEntrega  String?       @map("direccion_entrega")
  municipioEntrega  Municipio?    @map("municipio_entrega")
  notasCliente      String?       @map("notas_cliente")
  notasAdmin        String?       @map("notas_admin")
  entregadaEn       DateTime?     @map("entregada_en")
  canceladaEn       DateTime?     @map("cancelada_en")
  creadaEn          DateTime      @default(now()) @map("creada_en")
  actualizadaEn     DateTime      @updatedAt @map("actualizada_en")

  clienta           Clienta       @relation(fields: [clientaId], references: [id])
  producto          Producto      @relation(fields: [productoId], references: [id])
  comprobante       Comprobante?  @relation(fields: [comprobanteId], references: [id])
  solicitudesCancelacion SolicitudCancelacion[]

  @@index([clientaId])
  @@index([productoId])
  @@index([estatus])
  @@map("compras")
}

// ============================================
// COMPROBANTES DE PAGO
// ============================================

model Comprobante {
  id              String              @id @default(cuid())
  imagenUrl       String              @map("imagen_url") // path en bucket privado
  monto           Float
  metodoPago      MetodoPago          @map("metodo_pago")
  referenciaPago  String?             @map("referencia_pago")
  estatus         EstatusComprobante  @default(PENDIENTE)
  validadoPor     String?             @map("validado_por") // userId admin
  validadoEn      DateTime?           @map("validado_en")
  notasValidacion String?             @map("notas_validacion")
  creadoEn        DateTime            @default(now()) @map("creado_en")
  actualizadoEn   DateTime            @updatedAt @map("actualizado_en")

  compra          Compra?
  boleto          Boleto?

  @@index([estatus])
  @@map("comprobantes")
}

// ============================================
// CONFIGURACIÓN DEL SITIO
// ============================================

model ConfiguracionSitio {
  id                String   @id @default("default")
  nombreNegocio     String   @default("ASHA") @map("nombre_negocio")
  slogan            String?
  logoUrl           String?  @map("logo_url")
  colorPrimario     String   @default("#E91E63") @map("color_primario")
  colorSecundario   String   @default("#F8BBD0") @map("color_secundario")
  heroTitulo        String?  @map("hero_titulo")
  heroSubtitulo     String?  @map("hero_subtitulo")
  heroImagenUrl     String?  @map("hero_imagen_url")
  whatsappPrincipal String?  @map("whatsapp_principal")
  emailContacto     String?  @map("email_contacto")
  facebookUrl       String?  @map("facebook_url")
  instagramUrl      String?  @map("instagram_url")
  tiktokUrl         String?  @map("tiktok_url")
  textoLegal        String?  @map("texto_legal")
  actualizadoEn     DateTime @updatedAt @map("actualizado_en")

  @@map("configuracion_sitio")
}

// ============================================
// DINÁMICAS DE BOLETOS (Fase 2)
// ============================================

model Dinamica {
  id                 String           @id @default(cuid())
  nombre             String
  descripcion        String?
  tipo               TipoDinamica     @default(CLASICA)
  precioBoleto       Float            @map("precio_boleto")
  totalBoletos       Int              @map("total_boletos")
  productoPremioId   String?          @map("producto_premio_id")
  premioCustom       String?          @map("premio_custom") // si el premio no es del catálogo
  imagenPremioUrl    String?          @map("imagen_premio_url") // imagen del premio custom
  estatus            EstatusDinamica  @default(BORRADOR)
  inicioEn           DateTime?        @map("inicio_en")
  cierreEn           DateTime?        @map("cierre_en") // para express/flash
  seedGanadora       String?          @map("seed_ganadora") // seed aleatoria (UUID), se publica al cerrar
  hashSeed           String?          @map("hash_seed") // SHA256 del seed, público desde el inicio
  boletoGanador      Int?             @map("boleto_ganador") // número ganador, nullable hasta sortear
  clientaGanadoraId  String?          @map("clienta_ganadora_id")
  esHistorico        Boolean          @default(false) @map("es_historico") // dinámica previa al sistema verificable
  sorteadoEn         DateTime?        @map("sorteado_en")
  entregadoEn        DateTime?        @map("entregado_en")
  creadoEn           DateTime         @default(now()) @map("creado_en")
  actualizadoEn      DateTime         @updatedAt @map("actualizado_en")

  productoPremio     Producto?        @relation(fields: [productoPremioId], references: [id])
  clientaGanadora    Clienta?         @relation("ClientaGanadora", fields: [clientaGanadoraId], references: [id])
  boletos            Boleto[]
  historial          HistorialDinamica[]

  @@index([estatus])
  @@index([tipo])
  @@index([inicioEn])
  @@map("dinamicas")
}

model Boleto {
  id              String         @id @default(cuid())
  dinamicaId      String         @map("dinamica_id")
  numero          Int
  clientaId       String?        @map("clienta_id")
  estatus         EstatusBoleto  @default(DISPONIBLE)
  nombreCliente   String?        @map("nombre_cliente") // para compra anónima
  telefonoCliente String?        @map("telefono_cliente") // para compra anónima
  comprobanteId   String?        @unique @map("comprobante_id")
  reservadoEn     DateTime?      @map("reservado_en")
  confirmadoEn    DateTime?      @map("confirmado_en")
  canceladoEn     DateTime?      @map("cancelado_en")
  creadoEn        DateTime       @default(now()) @map("creado_en")
  actualizadoEn   DateTime       @updatedAt @map("actualizado_en")

  dinamica        Dinamica       @relation(fields: [dinamicaId], references: [id], onDelete: Cascade)
  clienta         Clienta?       @relation(fields: [clientaId], references: [id], onDelete: SetNull)
  comprobante     Comprobante?   @relation(fields: [comprobanteId], references: [id], onDelete: SetNull)
  solicitudesCancelacion SolicitudCancelacion[]

  @@unique([dinamicaId, numero]) // un número no puede repetirse en la misma dinámica
  @@index([dinamicaId])
  @@index([clientaId])
  @@index([estatus])
  @@map("boletos")
}

model HistorialDinamica {
  id               String          @id @default(cuid())
  dinamicaId       String          @map("dinamica_id")
  estatusAnterior  EstatusDinamica @map("estatus_anterior")
  estatusNuevo     EstatusDinamica @map("estatus_nuevo")
  userId           String?         @map("user_id") // quién hizo el cambio
  notas            String?
  creadoEn         DateTime        @default(now()) @map("creado_en")

  dinamica         Dinamica        @relation(fields: [dinamicaId], references: [id], onDelete: Cascade)

  @@index([dinamicaId])
  @@map("historial_dinamicas")
}

// ============================================
// CANCELACIONES
// ============================================

model SolicitudCancelacion {
  id                String                    @id @default(cuid())
  tipoOrigen        TipoOrigenCancelacion     @map("tipo_origen")
  boletoId          String?                   @map("boleto_id")
  compraId          String?                   @map("compra_id")
  clientaId         String                    @map("clienta_id")
  motivo            String
  estatus           EstatusSolicitudCancelacion @default(PENDIENTE)
  revisadaPor       String?                   @map("revisada_por") // userId admin
  revisadaEn        DateTime?                 @map("revisada_en")
  notasAdmin        String?                   @map("notas_admin")
  montoDevolucion   Float?                    @map("monto_devolucion")
  metodoDevolucion  MetodoDevolucion?         @map("metodo_devolucion")
  creadoEn          DateTime                  @default(now()) @map("creado_en")
  actualizadoEn     DateTime                  @updatedAt @map("actualizado_en")

  boleto            Boleto?                   @relation(fields: [boletoId], references: [id], onDelete: SetNull)
  compra            Compra?                   @relation(fields: [compraId], references: [id], onDelete: SetNull)
  clienta           Clienta                   @relation(fields: [clientaId], references: [id], onDelete: Cascade)

  @@index([estatus])
  @@index([clientaId])
  @@index([tipoOrigen])
  @@map("solicitudes_cancelacion")
}

// ============================================
// ENUMS
// ============================================

enum CategoriaProducto {
  LABIALES
  BASES
  OJOS
  RUBORES
  BROCHAS
  KITS
  CUIDADO_PIEL
  UNAS
  OTROS
}

enum Municipio {
  TONALA
  ZAPOPAN
  GUADALAJARA
  TLAQUEPAQUE
  OTRO
}

enum EstatusCompra {
  PENDIENTE
  PAGADO
  LISTO_ENTREGA
  ENTREGADO
  CANCELADO
}

enum EstatusComprobante {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum MetodoPago {
  TRANSFERENCIA
  EFECTIVO
  OXXO
}

enum NivelClienta {
  BRONCE
  PLATA
  ORO
}

// --- Fase 2: Dinámicas ---

enum TipoDinamica {
  CLASICA
  EXPRESS
  VIP
  FLASH
  COMBO_SORPRESA
  CAJA_SORPRESA
  SUBASTA
}

enum EstatusDinamica {
  BORRADOR
  ACTIVA
  LLENA
  GANADORA_SELECCIONADA
  ENTREGADA
  CANCELADA
}

enum EstatusBoleto {
  DISPONIBLE
  RESERVADO
  PENDIENTE_VALIDACION
  CONFIRMADO
  CANCELACION_SOLICITADA
  CANCELADO
}

enum EstatusSolicitudCancelacion {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum TipoOrigenCancelacion {
  BOLETO
  COMPRA
}

enum MetodoDevolucion {
  TRANSFERENCIA
  EFECTIVO
  SALDO_PUNTOS
}
